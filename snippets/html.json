{
    "!": {
        "prefix": ["!", "html5"],
        "body": [
            "<!DOCTYPE html>",
            "<html lang=\"${1:en}\">",
            "<head>",
            "\t<meta charset=\"UTF-8\">",
            "\t<meta name=\"viewport\" content=\"width=${2:device-width}, initial-scale=${3:1.0}\">",
            "\t<title>${5:Document}</title>",
            "</head>",
            "<body>",
            "\t${0}",
            "</body>",
            "</html>"
        ],
        "description": "Defines a template for an HTML5 document"
    },
